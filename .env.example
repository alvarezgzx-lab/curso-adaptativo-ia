# ── Claude ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# ── Middleware ────────────────────────────────────────────
MIDDLEWARE_PORT=4000
NODE_ENV=development
STATE_DB_PATH=./data/bayes-state.sqlite

# ── Moodle ────────────────────────────────────────────────
MOODLE_URL=http://localhost:8080
MOODLE_WS_TOKEN=
MOODLE_DB_HOST=moodle-db
MOODLE_DB_PORT=3306
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=changeme
MOODLE_DB_NAME=moodle
MOODLE_ADMIN_PASSWORD=changeme

# ── LRS (Learning Record Store — LRSQL, Yet Analytics) ────
LRS_ENDPOINT=http://localhost:8081/xapi/
LRS_KEY=
LRS_SECRET=
LRS_ADMIN_USER=admin
LRS_ADMIN_PASSWORD=changeme

# ── Adapt course (usadas por adapt-contrib-spoor al hacer build) ──
ADAPT_XAPI_ENDPOINT=${LRS_ENDPOINT}
ADAPT_XAPI_AUTH=
