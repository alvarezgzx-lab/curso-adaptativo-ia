# ── Claude ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# ── Middleware ────────────────────────────────────────────
MIDDLEWARE_PORT=4000
NODE_ENV=development

# ── Moodle ────────────────────────────────────────────────
MOODLE_URL=http://localhost:8080
MOODLE_WS_TOKEN=
MOODLE_DB_HOST=moodle-db
MOODLE_DB_PORT=3306
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=changeme
MOODLE_DB_NAME=moodle
MOODLE_ADMIN_PASSWORD=changeme

# ── Learning Locker (LRS) ─────────────────────────────────
LRS_ENDPOINT=http://localhost:8081/data/xAPI/
LRS_KEY=
LRS_SECRET=
LEARNINGLOCKER_APP_SECRET=changeme-min-32-chars-random-string
MONGO_URI=mongodb://ll-mongo:27017/learninglocker
REDIS_URL=redis://ll-redis:6379

# ── Adapt course (usadas por adapt-contrib-spoor al hacer build) ──
ADAPT_XAPI_ENDPOINT=${LRS_ENDPOINT}
ADAPT_XAPI_AUTH=
